{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/power-system-study/stage-1-project-file.schema.json",
  "title": "Power System Study App Stage 1 Project File",
  "description": "Schema-level validation for Stage 1 Rev C save/load/import boundaries. Semantic engineering validation remains in packages/validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "appVersion",
    "project",
    "equipment",
    "diagram",
    "scenarios",
    "tagCounters"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "appVersion": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "$ref": "#/$defs/ProjectMetadata"
    },
    "equipment": {
      "$ref": "#/$defs/EquipmentCollections"
    },
    "diagram": {
      "$ref": "#/$defs/DiagramModel"
    },
    "scenarios": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ScenarioModel"
      }
    },
    "calculationSnapshots": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/CalculationSnapshotPlaceholder"
      }
    },
    "tagCounters": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "validation": {
      "$ref": "#/$defs/ValidationSummary"
    }
  },
  "x-stage1-top-level-key-order": [
    "schemaVersion",
    "appVersion",
    "project",
    "equipment",
    "diagram",
    "scenarios",
    "calculationSnapshots",
    "tagCounters",
    "validation"
  ],
  "$defs": {
